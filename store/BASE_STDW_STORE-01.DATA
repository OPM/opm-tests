-- This deck tests usage of keyword STORE. The following simulation will create a 
-- STORE file at 15 OCT 2018. This file is used for restarting (keyword RESTART item3 = STORE) 
-- model RST_STORE_STDW-01.DATA. This model include one producer set ut using the 
-- standard well model.

------------------------------------------------------------------------------------------------
RUNSPEC
------------------------------------------------------------------------------------------------

DIMENS
 6 5 7 /

OIL
WATER
GAS
DISGAS
VAPOIL

METRIC

START
 10 'OCT' 2018 /

--
GRIDOPTS
'YES'		0 / 


EQLDIMS
 1 1*  25 /


--
REGDIMS
-- max. ntfip  nmfipr  max. nrfreg   max. ntfreg
   1          4       1*            1*    /

--
--
WELLDIMS
--max.well  max.con/well  max.grup  max.w/grup
  2         10            3        3   /

--
TABDIMS
--ntsfun     ntpvt  max.nssfun  max.nppvt  max.ntfip  max.nrpvt
  1          1      50          60         72         60 /

--
UNIFIN
UNIFOUT

--

------------------------------------------------------------------------------------------------
GRID
------------------------------------------------------------------------------------------------

--
NEWTRAN

--
GRIDFILE
0  1/

--
GRIDUNIT
METRES  /

--
INIT



INCLUDE
'include/mod2_6x5x7.grdecl' /

PORO
 30*0.25
 30*0.22
 30*0.17
 30*0.28
 30*0.14
 30*0.23
 30*0.22 /
 
PERMX
 30*2100
 30*1200
 30*800
 30*2500
 30*10
 30*1700
 30*1200 /

PERMZ
 30*210
 30*120
 30*80
 30*250
 30*1
 30*170
 30*120 /

NTG
 30*0.95
 30*0.88
 30*0.85
 30*0.70
 30*0.14
 30*0.77
 30*0.82 /


COPY
 PERMX PERMY /
/


RPTGRID
 'ALLNNC' /

------------------------------------------------------------------------------------------------  
EDIT
------------------------------------------------------------------------------------------------

INCLUDE
 'include/edit_nnc.inc' /

-- repeted NNC, should be product of first and second entry
EDITNNC
 3 1 3  4 1 1  0.0010 /
 3 2 3  4 2 1  0.0010 /
/

------------------------------------------------------------------------------------------------
PROPS
------------------------------------------------------------------------------------------------

NOECHO


INCLUDE
 'include/PVT-WET-GAS.INC' /



INCLUDE
 'include/scal_mod2.inc' /


FILLEPS


------------------------------------------------------------------------------------------------
REGIONS
------------------------------------------------------------------------------------------------

EQLNUM
 210*1 /
 
SATNUM
 210*1 /


------------------------------------------------------------------------------------------------
SOLUTION
------------------------------------------------------------------------------------------------

RPTSOL
SWAT FIP=3 THPRES EQUIL RECOV FIPRESV /

RPTRST
 BASIC=2 /

EQUIL
-- Datum    P     woc     Pc   goc    Pc  Rsvd  Rvvd
2281.00  268.56  2545.0   0.0  2281.00  0.0   1   0   0 /   C,D, and I segments: 		Not 2

RSVD
 2581.78  122.30
 2597.0   110.00
 2660.7   106.77
 2697.0   106.77 /


------------------------------------------------------------------------------------------------
SUMMARY
------------------------------------------------------------------------------------------------

INCLUDE
 'include/summary_stdw.inc' / 

------------------------------------------------------------------------------------------------
SCHEDULE
------------------------------------------------------------------------------------------------

-- start: 10  'OCT' 2018 /

WELSPECS 
   'D-1H'   'TEST'   2   2  1*       'OIL'  2*      'STOP'  4* /
/

COMPDAT 
-- WELL     I   J  K1   K2            Sat.      CF        DIAM        KH SKIN ND        DIR   Ro 
   'D-1H'   2   2   1	1      'OPEN'  1*      5.505	  0.216    510.312  2*         'Z'     15.511 /
   'D-1H'   2   2   2	2      'OPEN'  1*      0.101	  0.216      9.456  2*         'Z'     16.532 /
   'D-1H'   2   2   3	3      'OPEN'  1*      4.938	  0.216    452.905  2*         'Z'     14.704 /
   'D-1H'   2   2   4	4      'OPEN'  1*     19.086	  0.216   1745.284  2*         'Z'     14.493 /
/

WCONHIST 
   'D-1H'      'OPEN'      'RESV'   1500.0 0	300000.0  5* /
/

DATES
 15 OCT 2018 /
/

-- request a store file at 15 OCT 2018
STORE 

WCONHIST 
   'D-1H'      'OPEN'      'RESV'   900 0	180000  5* /
/

DATES 
 20 OCT 2018 /
/

WCONHIST 
   'D-1H'      'OPEN'      'RESV'   750 0	150000  5* /
/

DATES 
 25 OCT 2018 /
/

WCONHIST 
   'D-1H'      'OPEN'      'RESV'   600.0 0	120000  5* /
/
 
DATES
 1 NOV 2018 /
/


